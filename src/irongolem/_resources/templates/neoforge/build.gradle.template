plugins {
    id 'java'
    id 'net.neoforged.moddev' version '1.0.0'
}

group = 'io.irongolem.generated'
version = '0.1.0'

repositories {
    mavenLocal()
    mavenCentral()
}

java {
    toolchain {
        languageVersion = JavaLanguageVersion.of(21)
    }
}

dependencies {
    testImplementation 'io.irongolem:irongolem-lib-neoforge:0.1.0'
}

tasks.withType(Test).configureEach {
    useJUnitPlatform()
}
